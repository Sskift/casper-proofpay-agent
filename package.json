{
  "name": "casper-proofpay-agent",
  "version": "0.1.0",
  "private": true,
  "description": "ProofPay Agent: agentic RWA milestone escrow with Casper attestations.",
  "type": "module",
  "scripts": {
    "dev": "npm --workspace @proofpay/web run dev --",
    "build": "npm --workspace apps/web run build",
    "test": "npm --workspaces --if-present run test",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "submission:check": "node scripts/check-submission-clean.mjs",
    "attestation:export": "tsx scripts/export-attestation-payload.ts",
    "casper:check": "bash scripts/check-casper-testnet.sh",
    "contract:build": "bash scripts/build-contract.sh",
    "contract:deploy:print": "bash scripts/print-casper-deploy-command.sh",
    "contract:deploy:testnet": "bash scripts/deploy-casper-testnet.sh"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "tsx": "^4.22.4"
  }
}
